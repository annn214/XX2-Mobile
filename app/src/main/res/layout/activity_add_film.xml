<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_add"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:title="XX2"
            app:titleTextColor="@color/gold_accent"
            app:titleTextAppearance="@style/XX2_ToolbarTitle"
            app:titleMarginTop="10dp" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:src="?attr/homeAsUpIndicator"
                    app:tint="@android:color/white"
                    android:contentDescription="Kembali" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah Film Baru"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Judul Film"
                android:textColor="@color/gold_accent"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardElevation="0dp">
                <EditText
                    android:id="@+id/et_judul"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Masukkan judul film..."
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:inputType="textCapWords" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Genre"
                android:textColor="@color/gold_accent"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardElevation="0dp">
                <EditText
                    android:id="@+id/et_genre"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Contoh: Action, Sci-Fi, Horor"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:inputType="text" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="URL Poster Gambar"
                android:textColor="@color/gold_accent"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardElevation="0dp">
                <EditText
                    android:id="@+id/et_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="https://link-gambar-poster.com/image.jpg"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingHorizontal="16dp"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:inputType="textUri" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sinopsis / Deskripsi"
                android:textColor="@color/gold_accent"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="6dp"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardElevation="0dp">
                <EditText
                    android:id="@+id/et_deskripsi"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Tuliskan sinopsis singkat cerita film di sini..."
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:padding="16dp"
                    android:textSize="14sp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine" />
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_simpan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Simpan Film"
                android:textColor="@color/bg_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/gold_accent"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>