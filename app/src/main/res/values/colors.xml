<?xml version="1.0" encoding="utf-8"?>
<!--
    Skema warna "Dark Cinema" untuk CineVault
    ─────────────────────────────────────────
    Inspirasi: Netflix, HBO Max, bioskop premium
    Prinsip:
    - Background utama: hitam pekat (#0D0D0F) — memberikan kedalaman maksimal
    - Surface: hitam sedikit terang (#111116) — diferensiasi layer
    - Card: abu-abu sangat gelap (#1A1A22) — menonjolkan konten
    - Aksen utama: Gold/Amber (#E2B04A) — merepresentasikan kemewahan bioskop
    - Teks: Putih terang untuk utama, abu-abu untuk sekunder
-->
<resources>

    <!-- ── Background Layers ── -->
    <color name="bg_primary">#0D0D0F</color>         <!-- Latar paling gelap, halaman utama -->
    <color name="bg_surface">#111116</color>          <!-- Toolbar, navbar -->
    <color name="bg_card">#1A1A22</color>             <!-- Card film -->
    <color name="bg_shimmer_element">#252530</color>  <!-- Elemen skeleton shimmer -->

    <!-- ── Aksen Gold / Bioskop ── -->
    <color name="gold_accent">#E2B04A</color>         <!-- Warna utama: judul toolbar, badge, FAB -->
    <color name="gold_dark">#C4943A</color>            <!-- Versi gelap gold untuk pressed state -->
    <color name="gold_overlay">#33E2B04A</color>      <!-- Gold transparan untuk overlay -->

    <!-- ── Teks ── -->
    <color name="text_primary">#F0F0F0</color>        <!-- Judul, teks utama -->
    <color name="text_secondary">#9090A0</color>      <!-- Deskripsi, keterangan -->
    <color name="text_hint">#505060</color>           <!-- Placeholder input -->

    <!-- ── UI Elements ── -->
    <color name="divider_color">#1F1F2A</color>       <!-- Garis pemisah -->
    <color name="input_stroke_default">#2A2A38</color> <!-- Border input saat tidak fokus -->
    <color name="input_stroke_focused">#E2B04A</color> <!-- Border input saat fokus -->

    <!-- ── Status / Semantic ── -->
    <color name="status_available">#4ADE80</color>    <!-- Film tersedia -->
    <color name="status_error">#F87171</color>        <!-- Error message -->

    <!-- ── Material Theme Required ── -->
    <!-- Warna ini dibutuhkan oleh tema Material Components Android -->
    <color name="colorPrimary">#E2B04A</color>
    <color name="colorPrimaryVariant">#C4943A</color>
    <color name="colorOnPrimary">#0D0D0F</color>
    <color name="colorSecondary">#534AB7</color>
    <color name="colorOnSecondary">#FFFFFF</color>
    <color name="colorSurface">#111116</color>
    <color name="colorOnSurface">#F0F0F0</color>
    <color name="colorBackground">#0D0D0F</color>
    <color name="colorOnBackground">#F0F0F0</color>
    <color name="colorError">#F87171</color>
    <color name="colorOnError">#0D0D0F</color>

</resources>